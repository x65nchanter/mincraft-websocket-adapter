  "authors": ["Me!"],
  "contact": {
    "homepage": "https://fabricmc.net/",
    "sources": "https://github.com/FabricMC/fabric-example-mod"
  },
  "license": "CC0-1.0",
  "icon": "assets/minecraft-websocket-bridge/icon.png",
  "environment": "*",
  "entrypoints": {
    "main": ["pro.azenord.mwb.MinecraftWebsocketBridgeServer"],
    "client": ["pro.azenord.mwb.client.MinecraftWebsocketBridgeClient"]
